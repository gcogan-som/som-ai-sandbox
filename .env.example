# Firebase Web SDK config (Firebase Console → Project settings → Your apps → Web app)
# Copy this file to ".env.local" for local dev. Never commit .env.local.
# CI/CD: inject these as encrypted secrets / variables at build time (e.g. GitHub Actions secrets).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
